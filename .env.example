# ----------------------------------------------------------------------------
# Mnemo — environment variable template
# Copy to .env.local and fill in values. Never commit .env.local.
# ----------------------------------------------------------------------------

# Database (Neon Postgres serverless)
DATABASE_URL=

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (Better Auth provider)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Gemini (default AI provider via Vercel AI SDK — free tier during beta)
GOOGLE_GENERATIVE_AI_API_KEY=

# Anthropic Claude (optional premium fallback)
ANTHROPIC_API_KEY=

# Resend (transactional email)
RESEND_API_KEY=

# PostHog (analytics — public keys)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry (error tracking + source-map upload at build time)
# NEXT_PUBLIC_SENTRY_DSN is read by instrumentation-client.ts; use the same value as SENTRY_DSN.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Cloudflare R2 (S3-compatible object storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Beta mode (controls feature access + signup cap)
BETA_MODE=true
BETA_USER_LIMIT=100

# Cron auth — Vercel cron sends "Authorization: Bearer $CRON_SECRET" to /api/cron/*
CRON_SECRET=
