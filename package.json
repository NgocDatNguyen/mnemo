{
	"name": "mnemo",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "biome check",
		"format": "biome format --write",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"db:generate": "node --env-file=.env.local ./node_modules/drizzle-kit/bin.cjs generate",
		"db:push": "node --env-file=.env.local ./node_modules/drizzle-kit/bin.cjs push",
		"db:migrate": "node --env-file=.env.local ./node_modules/drizzle-kit/bin.cjs migrate",
		"db:studio": "node --env-file=.env.local ./node_modules/drizzle-kit/bin.cjs studio"
	},
	"dependencies": {
		"@ai-sdk/anthropic": "^3.0.78",
		"@ai-sdk/google": "^3.0.75",
		"@aws-sdk/client-s3": "^3.1048.0",
		"@neondatabase/serverless": "^1.1.0",
		"@sentry/nextjs": "^10.53.1",
		"@tanstack/react-query": "^5.100.10",
		"ai": "^6.0.184",
		"better-auth": "^1.6.11",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.45.2",
		"next": "16.2.6",
		"pino": "^10.3.1",
		"posthog-js": "^1.374.0",
		"posthog-node": "^5.34.3",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"resend": "^6.12.3",
		"tailwind-merge": "^3.6.0",
		"ts-fsrs": "^5.4.0",
		"uuidv7": "^1.2.1",
		"zod": "^4.4.3"
	},
	"devDependencies": {
